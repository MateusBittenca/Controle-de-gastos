# PostgreSQL (Docker)
POSTGRES_USER=financas
POSTGRES_PASSWORD=financas_dev
POSTGRES_DB=financas
POSTGRES_PORT=5432

DATABASE_URL=postgresql://financas:financas_dev@localhost:5432/financas

# API
API_PORT=3000
API_HOST=0.0.0.0
JWT_SECRET=altere-este-segredo-em-producao
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Recuperação de senha (link no e-mail aponta para o front)
APP_URL=http://localhost:5173

# SMTP (opcional em dev — sem SMTP o link aparece no console da API)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=re_xxxx
# SMTP_FROM=Finanças <noreply@seudominio.com>

# Adminer (docker compose --profile tools up -d)
ADMINER_PORT=8080
